# Nothing Store - Environment Variables
# Copy this file to .env.local and customize for your deployment

# Store Branding
NEXT_PUBLIC_STORE_NAME="Nothing Store"

# Currency Settings (USD, EUR, GBP, JPY)
NEXT_PUBLIC_CURRENCY="USD"
NEXT_PUBLIC_CURRENCY_SYMBOL="$"

# Product Configuration
# Comma-separated list of product variants to show
NEXT_PUBLIC_PRODUCT_VARIANTS="premium,deluxe,ultimate,starter"

# Internationalization (i18n)
# Default language when no preference is stored
NEXT_PUBLIC_DEFAULT_LOCALE="en"
# Supported locales (used by language selector)
NEXT_PUBLIC_SUPPORTED_LOCALES="en,es,fr,de,sw"

# Satirical Features (Optional)
NEXT_PUBLIC_DEMO_MODE="true"               # Show demo mode warnings
NEXT_PUBLIC_ENABLE_ANALYTICS="false"       # Disable analytics

# GitHub Pages Deployment
# When deploying to GitHub Pages, set this env var at build time:
# GITHUB_PAGES=true npm run build
# This enables static export with basePath '/nothing'
# See README.md for full GitHub Pages deployment instructions

# Important Note:
# All values use NEXT_PUBLIC_ prefix for client-side access
# In production, set these in Vercel dashboard, not in .env.local
# .env.local should NEVER be committed to git
